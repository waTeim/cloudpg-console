{
  "name": "cloudpg-console",
  "version": "0.1.0",
  "description": "Desktop psql interface for CloudNativePG (CNPG) clusters across kubernetes contexts.",
  "author": "CloudPG Console contributors",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "node scripts/build.js",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "package:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.21.0",
    "pg": "^8.13.0"
  }
}
